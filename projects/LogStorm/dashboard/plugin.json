{
  "id": "dashboard",
  "type": "system",
  "version": "1.0.0",
  "description": "JavaFX live dashboard. Displays real-time metrics and controls Play/Stop.",
  "lifecycle": {
    "mode": "persistent"
  },
  "launch": {
