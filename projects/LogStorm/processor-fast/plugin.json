{
  "id": "processor-fast",
  "type": "tool",
  "version": "1.0.0",
  "description": "Fast log processor. High bid weight, low latency. Shares ProcessorTool.java.",
  "lifecycle": {
    "mode": "on-demand",
    "idleTimeoutSeconds": 60
  },
  "processorConfig": {
    "delayMs": 5
  },
  "launch": {
    "name": "ProcessorFast",
    "command": ["jbang", "../processor/ProcessorTool.java"],
    "order": 40
  },
  "capabilities": [
    {
      "name": "log.process",
      "description": "Fast log classification and enrichment.",
      "triggerEvent": "capability.tool.log.process",
      "bidWeight": 1.5,
      "exclusive": false
    }
  ],
  "subscribes": [
    "capability.tool.log.process"
  ],
  "publishes": [
    "capability.result",
    "storm.metric"
  ]
}
